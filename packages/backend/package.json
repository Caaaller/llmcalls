{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "dev:watch": "nodemon --watch src --exec ts-node src/server.ts",
    "test": "jest --runInBand",
    "test:info-request": "jest --runInBand --forceExit --testPathIgnorePatterns=/node_modules/ --testPathPatterns=infoRequest",
    "test:live": "jest --runInBand --forceExit --testPathIgnorePatterns=/node_modules/ --testPathPatterns=liveCallEval",
    "test:live:record": "RECORD_CALLS=1 jest --runInBand --forceExit --testPathIgnorePatterns=/node_modules/ --testPathPatterns=liveCallEval",
    "verify:testrun": "ts-node src/scripts/verifyLatestTestRun.ts",
    "test:replay": "REPLAY_EVAL_CONCURRENCY=1 jest --runInBand --forceExit --testPathIgnorePatterns=/node_modules/ --testPathPatterns=replayCallEval",
    "test:replay-or-live": "TEST_MODE=replay-or-live jest --runInBand --forceExit --testPathIgnorePatterns=/node_modules/ --testPathPatterns=replayCallEval",
    "test:stt": "jest --runInBand --forceExit --testPathIgnorePatterns=/node_modules/ --testPathPatterns=sttEval",
    "test:stt-compare": "jest --runInBand --forceExit --testPathPatterns=sttModelComparison",
    "test:prompts": "jest --runInBand --forceExit --testPathIgnorePatterns=/node_modules/ --testPathPatterns=promptEvaluation",
    "eval:prompts": "ts-node src/scripts/run-all-evals.ts",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src/**/*.ts",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@deepgram/sdk": "^5.0.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.4",
    "openai": "^6.16.0",
    "telnyx": "^6.29.2",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.10",
    "@types/supertest": "^7.2.0",
    "@types/twilio": "^3.19.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
